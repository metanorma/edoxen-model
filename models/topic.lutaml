class Topic {
  identifier: String
  urn: String
  title: LocalizedString[0..*]
  description: LocalizedString[0..*]
  status: TopicStatus
  resumptionOf: String
  documents: TopicDocument[0..*]
  assets: TopicAsset[0..*]
  references: Reference[0..*]
  motions: String[0..*]
  decisions: String[0..*]
  statements: Statement[0..*]
  declarations: Declaration[0..*]
  extensions: MeetingExtension[0..*]
}
