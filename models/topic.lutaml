class Topic {
  identifier: String
  urn: String
  title: String
  description: String
  status: TopicStatus
  resumptionOf: String
  documents: TopicDocument[0..*]
  assets: TopicAsset[0..*]
  references: Reference[0..*]
  motions: String[0..*]
  decisions: String[0..*]
  extensions: MeetingExtension[0..*]
}
