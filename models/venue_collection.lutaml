// VenueCollection — registry of Venues, indexed by scoped URN.
//
// Mirrors ContactCollection: members carry
// `urn: urn:edoxen:venue:{scope}:{local-id}`; the collection's `scope`
// MUST match the scope segment in member URNs.
class VenueCollection {
  scope: String
  title: LocalizedString[0..*]
  venues: Venue[0..*]
  extensions: MeetingExtension[0..*]
}
