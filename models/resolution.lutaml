class Resolution {
  identifier: StructuredIdentifier[1..*]
  type: ResolutionType
  doi: String
  urn: String
  agendaItem: String
  dates: ResolutionDate[1..*]
  categories: String[0..*]
  meeting: MeetingIdentifier
  relations: ResolutionRelation[0..*]
  urls: Url[0..*]
  localizations: Localization[1..*]
}
